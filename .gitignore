# Python
__pycache__/
*.pyc
*.pyo
*.pyd


.pgdata/
.idea/

# Virtual environment
.env
.env.prod
.env.staging
.venv/
venv/

# IDE / Editor
.vscode/
*.sublime-project
*.sublime-workspace

# OS
.DS_Store

# Database
*.db

# pytest cache
.pytest_cache/

# Uvicorn / log files
*.log

# External staging artifacts (never commit secrets/certs)
ops/external-staging/nginx/.htpasswd
ops/external-staging/nginx/tls/

# Backup artifacts (never commit dumps, encrypted blobs, or sidecars)
backups/

# Off-host backup destination credentials / config (never commit)
.env.offhost
.env.restore

# Encryption keys: NEVER commit private identities/passphrases.
# Public recipients (age-recipients.txt) are safe to commit, so they are
# *not* ignored. Identity files / passphrases are.
ops/backup/age-identity*
ops/backup/*.identity
ops/backup/*.passphrase
*.age.key
*.gpg.passphrase
