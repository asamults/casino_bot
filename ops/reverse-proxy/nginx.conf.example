events {}

http {
  upstream casino_bot_api {
    server api:8000;
  }

  server {
    listen 8080;

    # App API (no auth here; enforce separately if needed)
    location / {
      proxy_set_header Host $host;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
      proxy_set_header X-Forwarded-Proto $scheme;
      proxy_pass http://casino_bot_api;
    }

    # Metrics protected by basic auth (example)
    location = /metrics {
      auth_basic "metrics";
      auth_basic_user_file /etc/nginx/.htpasswd;

      proxy_set_header Host $host;
      proxy_pass http://casino_bot_api/metrics;
    }
  }
}

