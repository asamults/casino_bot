# Env file for the *restore* compose stack (docker-compose.restore.yml).
# Used by scripts/ops/restore_isolated_compose.sh. Do not commit real secrets.
#
# This stack is deliberately ephemeral and isolated from the running prod
# stack. It is brought up under a project name like
#   casino_bot_restore_<timestamp>
# so containers, networks, and volumes are namespaced and cannot collide
# with the production compose project.

POSTGRES_USER=casino
POSTGRES_PASSWORD=secret
POSTGRES_DB=casino_db

# DATABASE_URL must point at the *restore* postgres service (compose service name).
DATABASE_URL=postgresql+psycopg://casino:secret@postgres:5432/casino_db

SECRET_KEY=restore_secret_key_minimum_length_32
JWT_SIGNING_KEY=restore_jwt_signing_key_minimum_le32
REFRESH_TOKEN_PEPPER=restore_refresh_pepper_minimum_le32
USER_API_INTERNAL_TOKEN=restore_user_api_internal_token_min32

CORS_ALLOW_ORIGINS=["https://admin.example.com"]
ALLOWED_HOSTS=api.example.com
BILLING_ALLOWED_RETURN_HOSTS=admin.example.com

BILLING_PROVIDER_PRIMARY=stripe
BILLING_ENABLE_WEBHOOKS=false
BILLING_FAIL_ON_MISSING_SECRETS_IN_PROD=true
STRIPE_WEBHOOK_SECRET=
PADDLE_WEBHOOK_SECRET=

# Host header used by the readiness probe inside the api container.
HEALTHCHECK_HOST=api.example.com
