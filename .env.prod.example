# Production-like compose example.
# Copy to .env.prod (do not commit real secrets).

POSTGRES_USER=casino
POSTGRES_PASSWORD=secret
POSTGRES_DB=casino_db

# For docker-compose.prod.yml, DATABASE_URL points to the compose service name `postgres`.
DATABASE_URL=postgresql+psycopg://casino:secret@postgres:5432/casino_db

# Required production secrets (examples only; use real random values in deployments).
SECRET_KEY=prod_secret_key_minimum_length_32__
JWT_SIGNING_KEY=prod_jwt_signing_key_minimum_len_32
REFRESH_TOKEN_PEPPER=prod_refresh_pepper_minimum_len_32
USER_API_INTERNAL_TOKEN=prod_user_api_internal_token_min_len_32_____

# Host hardening
# CORS: must be valid JSON. Use single quotes so `source .env.prod` keeps the
# string as ["https://..."] (unquoted CORS_ALLOW_ORIGINS=[...] makes bash mangle
# the value and Settings() JSON parsing fails).
CORS_ALLOW_ORIGINS='["https://admin.example.com"]'
ALLOWED_HOSTS=api.example.com
# Same as primary API hostname (first value if you later list multiple in ALLOWED_HOSTS).
HEALTHCHECK_HOST=api.example.com
BILLING_ALLOWED_RETURN_HOSTS=admin.example.com

# Billing toggles
BILLING_PROVIDER_PRIMARY=stripe
BILLING_ENABLE_WEBHOOKS=false
BILLING_FAIL_ON_MISSING_SECRETS_IN_PROD=true
STRIPE_WEBHOOK_SECRET=
PADDLE_WEBHOOK_SECRET=

# Telegram — API container: often disabled here if polling runs on a host systemd unit.
# Host-only polling: put the same keys in /etc/casino-bot/telegram.env (chmod 600); see
# docs/ops/telegram-polling-production-runbook.md and docs/ops/telegram-polling-prod-env.example
ENVIRONMENT=production
# TELEGRAM_BOT_TOKEN=<set on host only; BotFather /token>
TELEGRAM_BOT_ENABLED=false
# When TELEGRAM_BOT_ENABLED=true and ENVIRONMENT=production, this list MUST include production:
TELEGRAM_POLLING_ALLOWED_ENVIRONMENTS=development,staging
# Example for a deliberate production poller (uncomment and set token on server, not in git):
# TELEGRAM_BOT_ENABLED=true
# TELEGRAM_POLLING_ALLOWED_ENVIRONMENTS=development,staging,production
# Optional /support copy (empty = generic line). Do not put production PII in repo defaults.
TELEGRAM_SUPPORT_TEXT=
SUPPORT_CONTACT_URL=

# Phase 2 — game engine (JSON list; single-quoted for bash `source`)
GAMES_ENABLED='["coin_flip"]'
COIN_FLIP_MIN_BET=1
COIN_FLIP_MAX_BET=100
# Explicit cooldown recommended (effective default is 3s if left at 0; see Settings.effective_coin_flip_cooldown_seconds).
COIN_FLIP_COOLDOWN_SECONDS=3
# Only if you truly want zero cooldown in production:
# COIN_FLIP_ALLOW_ZERO_COOLDOWN_IN_PRODUCTION=true

# Phase 5 — optional second game (enable by adding "bonus_wheel" to GAMES_ENABLED)
BONUS_WHEEL_MIN_BET=1
BONUS_WHEEL_MAX_BET=100
BONUS_WHEEL_COOLDOWN_SECONDS=3

# Phase 6 — minimum token balance to enter game flows (reject access_tokens_required before stake).
GAME_ACCESS_MIN_TOKENS=1
TOKEN_UNIT_SCALE=1000
TOKEN_PACKAGE_100_PRICE_GBP=1
TOKEN_PACKAGE_1000_PRICE_GBP=5
TOKEN_PACKAGE_10000_PRICE_GBP=20

TELEGRAM_FLIP_PROMPT_RATE_LIMIT_PER_MINUTE=30
TELEGRAM_FLIP_ACTION_RATE_LIMIT_PER_MINUTE=60
TELEGRAM_ROUNDS_HISTORY_LIMIT=15

