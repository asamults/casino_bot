# Production-like compose example.
# Copy to .env.prod (do not commit real secrets).

POSTGRES_USER=casino
POSTGRES_PASSWORD=secret
POSTGRES_DB=casino_db

# For docker-compose.prod.yml, DATABASE_URL points to the compose service name `postgres`.
DATABASE_URL=postgresql+psycopg://casino:secret@postgres:5432/casino_db

# Required production secrets (examples only; use real random values in deployments).
SECRET_KEY=prod_secret_key_minimum_length_32__
JWT_SIGNING_KEY=prod_jwt_signing_key_minimum_len_32
REFRESH_TOKEN_PEPPER=prod_refresh_pepper_minimum_len_32
USER_API_INTERNAL_TOKEN=prod_user_api_internal_token_min_len_32_____

# Host hardening
# CORS: must be valid JSON. Use single quotes so `source .env.prod` keeps the
# string as ["https://..."] (unquoted CORS_ALLOW_ORIGINS=[...] makes bash mangle
# the value and Settings() JSON parsing fails).
CORS_ALLOW_ORIGINS='["https://admin.example.com"]'
ALLOWED_HOSTS=api.example.com
# Same as primary API hostname (first value if you later list multiple in ALLOWED_HOSTS).
HEALTHCHECK_HOST=api.example.com
BILLING_ALLOWED_RETURN_HOSTS=admin.example.com

# Billing toggles
BILLING_PROVIDER_PRIMARY=stripe
BILLING_ENABLE_WEBHOOKS=false
BILLING_FAIL_ON_MISSING_SECRETS_IN_PROD=true
STRIPE_WEBHOOK_SECRET=
PADDLE_WEBHOOK_SECRET=

# Telegram: keep disabled in production unless you operate a deliberate polling deployment.
# TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_ENABLED=false
TELEGRAM_POLLING_ALLOWED_ENVIRONMENTS=development,staging

