# Copy to .env and adjust. Do not commit real secrets.

# development | staging | production
ENVIRONMENT=development

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# SQLAlchemy URL (Postgres + psycopg3): postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME
#
# HOST on your laptop (alembic, uvicorn outside Docker): use localhost (port 5432 if Postgres is mapped).
# HOST name "postgres" only resolves inside the Compose network (the api service); it will fail on the host.
# USER/PASSWORD must match Postgres (this repo's compose: user=casino, password=secret, db=casino_db).
DATABASE_URL=postgresql+psycopg://casino:secret@localhost:5432/casino_db

# Legacy compatibility key (kept for one transition release)
SECRET_KEY=DEV_ONLY_CHANGE_ME

# Primary JWT signing key (production: >=32 chars, not default)
JWT_SIGNING_KEY=DEV_ONLY_CHANGE_ME

# Secret used to HMAC refresh tokens before storing in DB (production: >=32 chars)
REFRESH_TOKEN_PEPPER=DEV_REFRESH_PEPPER_CHANGE_ME

# Auth/session TTL
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14

# Brute-force lockout policy
MAX_LOGIN_ATTEMPTS=5
ATTEMPT_WINDOW_SECONDS=300
LOCKOUT_SECONDS=900

# Rate limits per minute
LOGIN_RATE_LIMIT_PER_MINUTE=5
REFRESH_RATE_LIMIT_PER_MINUTE=30
READ_RATE_LIMIT_PER_MINUTE=120
WRITE_RATE_LIMIT_PER_MINUTE=30

# CORS / host hardening
# JSON list (required; pydantic-settings decodes complex env values as JSON)
CORS_ALLOW_ORIGINS=["http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PATCH,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Request-ID
ALLOWED_HOSTS=localhost,127.0.0.1

# Billing webhooks (Layer 4.1)
BILLING_PROVIDER_PRIMARY=stripe
BILLING_ENABLE_WEBHOOKS=false
BILLING_ENABLE_CHECKOUT=false
BILLING_FAIL_ON_MISSING_SECRETS_IN_PROD=true
STRIPE_WEBHOOK_SECRET=
PADDLE_WEBHOOK_SECRET=
STRIPE_API_KEY=
PADDLE_API_KEY=
USER_API_INTERNAL_TOKEN=dev-user-api-token
BILLING_ALLOWED_PLANS=test_plan,pro_monthly
BILLING_ALLOWED_RETURN_HOSTS=localhost,127.0.0.1
BILLING_WEBHOOK_TOLERANCE_SECONDS=300
BILLING_DEAD_LETTER_ATTEMPTS=5
BILLING_WEBHOOK_RETENTION_DAYS=90
BILLING_ENABLE_PORTAL=true
BILLING_POLICY_TOS_URL=
BILLING_POLICY_REFUND_URL=
BILLING_POLICY_CANCELLATION_URL=
ENTITLEMENT_GRACE_SECONDS=0
ENTITLEMENT_ENFORCEMENT_MODE=hard
